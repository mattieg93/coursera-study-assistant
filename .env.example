# ── Coursera Study Assistant — local config ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.

# Google Docs — your Doc ID lives in the URL:
#   https://docs.google.com/document/d/<DOC_ID>/edit
CSA_DOC_ID=

# Ollama — path to the directory where your models are stored
OLLAMA_MODELS=

# Ollama model to use for note generation
CSA_MODEL=granite3.2:8b

# Path to your Google service account credentials JSON file
# Defaults to src/coursera_agent/credentials.json if left blank
CSA_CREDENTIALS_PATH=
